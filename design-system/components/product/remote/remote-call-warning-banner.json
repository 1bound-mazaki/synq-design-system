{
  "name": "RemoteCallWarningBanner",
  "description": "通話準備画面の権限警告バナー。黄色背景+警告アイコン+メッセージ+「再取得」リンク。カメラ/マイクの利用許可を促す。",
  "category": "product",
  "composedOf": ["Text", "Link"],
  "_figmaSource": "SR-PRO > WarnCallCamera / WarnCallMic (node 26255:179611)",

  "structure": {
    "container": {
      "description": "警告バナー",
      "bg": "#F6E647",
      "height": "45px",
      "borderRadius": "2px",
      "padding": "12px 16px",
      "layout": "flex, gap 12px, align-items center"
    },
    "icon": {
      "description": "警告アイコン",
      "icon": "warning, 20px, {text.primary}"
    },
    "message": {
      "description": "警告メッセージ",
      "typography": "{typography.bodySm}(12px)",
      "color": "{text.primary}",
      "flex": "1"
    },
    "retryLink": {
      "description": "「再取得」リンク",
      "typography": "{typography.bodyMd}(14px)",
      "color": "{text.brand}(#005AFF)",
      "cursor": "pointer",
      "flexShrink": "0"
    }
  },

  "props": {
    "type": { "type": "enum", "values": ["camera", "mic"], "required": true, "description": "警告タイプ" },
    "message": { "type": "string", "required": true, "description": "警告メッセージ（例: カメラの利用を許可してください）" },
    "onRetry": { "type": "function", "description": "再取得リンクのコールバック" }
  },

  "_figmaColorMapping": {
    "#F6E647": "Figma warn.sf → DS該当なし。通話系の警告バナー色"
  },

  "accessibility": {
    "container": "role=alert",
    "retryLink": "aria-label='権限を再取得'"
  },

  "usage": {
    "do": [
      "通話準備画面のビデオプレビュー下に配置",
      "カメラ/マイクの権限が拒否されている場合に表示"
    ],
    "doNot": [
      "通常画面の通知には使わない（Notify を使う）"
    ]
  },

  "examples": [
    {
      "name": "カメラ警告",
      "code": "<RemoteCallWarningBanner type=\"camera\" message=\"カメラの利用を許可してください\" />"
    },
    {
      "name": "マイク警告",
      "code": "<RemoteCallWarningBanner type=\"mic\" message=\"マイクの利用を許可してください\" />"
    }
  ]
}
