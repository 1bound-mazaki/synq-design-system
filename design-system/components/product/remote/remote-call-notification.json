{
  "name": "RemoteCallNotification",
  "description": "やりとりスレッド内の通話通知カード。「通話が開始されました」等のシステムメッセージ+通話ステータスピル+参加ボタン。",
  "category": "product",
  "composedOf": ["Text", "Button", "Badge"],
  "_figmaSource": "SR-PRO > TimelineCall (node 26908:385165)",

  "structure": {
    "container": {
      "description": "中央寄せの通知カード",
      "bg": "#F8F8F9",
      "borderRadius": "4px",
      "padding": "16px",
      "width": "343px",
      "margin": "0 auto",
      "layout": "flex-col, gap 12px, align-items center"
    },
    "message": {
      "description": "通知メッセージ",
      "typography": "{typography.bodyMd}(14px)",
      "fontWeight": "bold",
      "color": "{text.primary}",
      "textAlign": "center"
    },
    "callingStatus": {
      "description": "通話ステータスピル（通話中/終了済）",
      "layout": "flex, gap 6px, align-items center",
      "borderRadius": "9999px",
      "padding": "4px 12px 4px 8px",
      "variants": {
        "active": {
          "bg": "#5AC462",
          "icon": "call, 16px, {text.inverse}",
          "text": "「通話中」, {typography.bodySm}(12px), fontWeight bold, {text.inverse}"
        },
        "ended": {
          "bg": "{bg.subtle}(#E1E2E4)",
          "icon": "call_end, 16px, {text.tertiary}",
          "text": "「終了」, {typography.bodySm}(12px), fontWeight bold, {text.tertiary}"
        }
      }
    },
    "joinButton": {
      "description": "通話参加ボタン（active 時のみ表示）",
      "component": "Button(primary)",
      "text": "「通話に参加する」",
      "height": "44px",
      "width": "100%",
      "borderRadius": "4px"
    },
    "timestamp": {
      "description": "通話開始/終了時刻",
      "typography": "{typography.bodySm}(12px)",
      "color": "{text.tertiary}"
    }
  },

  "props": {
    "message": { "type": "string", "required": true, "description": "通知メッセージ（例: 通話が開始されました）" },
    "callStatus": { "type": "enum", "values": ["active", "ended"], "required": true, "description": "通話ステータス" },
    "timestamp": { "type": "string", "required": true, "description": "時刻（例: 14:30）" },
    "onJoinCall": { "type": "function", "description": "通話参加ボタンのコールバック" }
  },

  "_figmaColorMapping": {
    "#F8F8F9": "Figma sf.hover → DS {bg.muted}(#f5f5f5) に最寄り",
    "#5AC462": "Figma sp.callIndicator → DS該当なし。Remote固有の通話アクティブ色"
  },

  "accessibility": {
    "container": "role=status, aria-live='polite'",
    "joinButton": "aria-label='通話に参加する'"
  },

  "usage": {
    "do": [
      "やりとり詳細のメッセージスレッド内にインラインで配置",
      "通話が開始されたタイムラインの位置に挿入する",
      "active 時のみ joinButton を表示"
    ],
    "doNot": [
      "通話履歴ページには使わない（RemoteCallHistoryItem を使う）",
      "スレッド外の通知には使わない"
    ]
  },

  "examples": [
    {
      "name": "通話中",
      "code": "<RemoteCallNotification message=\"通話が開始されました\" callStatus=\"active\" timestamp=\"14:30\" />"
    },
    {
      "name": "通話終了",
      "code": "<RemoteCallNotification message=\"通話が終了しました\" callStatus=\"ended\" timestamp=\"15:00\" />"
    }
  ]
}
